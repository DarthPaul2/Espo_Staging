{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "aktiv": {
            "notNull": true,
            "type": "bool",
            "default": true,
            "isCustom": true
        },
        "quelleTyp": {
            "type": "enum",
            "options": [
                "CRechnung",
                "CEingangsrechnung",
                "CZahlung"
            ],
            "style": {
                "CRechnung": null,
                "CEingangsrechnung": null,
                "CZahlung": null
            },
            "default": "CRechnung",
            "maxLength": 100,
            "isCustom": true
        },
        "dokumentTyp": {
            "type": "enum",
            "options": [
                "einzelrechnung",
                "eingangsrechnung",
                "zahlungseingang",
                "zahlungsausgang"
            ],
            "style": {
                "einzelrechnung": null,
                "eingangsrechnung": null,
                "zahlungseingang": null,
                "zahlungsausgang": null
            },
            "default": "einzelrechnung",
            "maxLength": 100,
            "isCustom": true
        },
        "steuerFall": {
            "type": "enum",
            "options": [
                "normal",
                "ermaessigt",
                "13b",
                "steuerfrei"
            ],
            "style": {
                "normal": null,
                "ermaessigt": null,
                "13b": null,
                "steuerfrei": null
            },
            "default": "normal",
            "maxLength": 100,
            "isCustom": true
        },
        "buchungsregelnDebit": {
            "type": "link"
        },
        "buchungsregelnErloes": {
            "type": "link"
        },
        "buchungsregelnSteuer": {
            "type": "link"
        },
        "beschreibung": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "phase1Verwendet": {
            "notNull": true,
            "type": "bool",
            "default": true,
            "isCustom": true
        },
        "aufwandKontoRegeln": {
            "type": "link"
        },
        "vorsteuerKontoRegeln": {
            "type": "link"
        },
        "verbindlichkeitKontoRegeln": {
            "type": "link"
        },
        "bankKontoRegeln": {
            "type": "link"
        },
        "kasseKontoRegeln": {
            "type": "link"
        },
        "forderungKontoRegeln": {
            "type": "link"
        },
        "verbindlichkeitZahlungKontoRegeln": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "buchungsregelnDebit": {
            "type": "belongsTo",
            "foreign": "debitKonto",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "buchungsregelnErloes": {
            "type": "belongsTo",
            "foreign": "creditKontoNetto",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "buchungsregelnSteuer": {
            "type": "belongsTo",
            "foreign": "creditKontoSteuer",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "buchungen": {
            "type": "hasMany",
            "foreign": "buchungsregel",
            "entity": "CBuchung",
            "audited": false,
            "isCustom": true
        },
        "aufwandKontoRegeln": {
            "type": "belongsTo",
            "foreign": "debitKontoAufwand",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "vorsteuerKontoRegeln": {
            "type": "belongsTo",
            "foreign": "debitKontoVorsteuer",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "verbindlichkeitKontoRegeln": {
            "type": "belongsTo",
            "foreign": "creditKontoVerbindlichkeit",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "bankKontoRegeln": {
            "type": "belongsTo",
            "foreign": "bankKontoRegeln",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "kasseKontoRegeln": {
            "type": "belongsTo",
            "foreign": "kasseKontoRegeln",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "forderungKontoRegeln": {
            "type": "belongsTo",
            "foreign": "forderungKontoRegeln",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        },
        "verbindlichkeitZahlungKontoRegeln": {
            "type": "belongsTo",
            "foreign": "verbindlichkeitZahlungKontoRegeln",
            "entity": "CKonto",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}