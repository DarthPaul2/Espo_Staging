{
    "hooks": {
        "beforeSave": [
            "CalculateGesamtNetto",
            "PreventEditIfParentFestgeschrieben"
        ],
        "afterSave": [
            "RecalculateParentTotals"
        ],
        "beforeRemove": [
            "PreventDeleteIfParentFestgeschrieben"
        ],
        "afterRemove": [
            "RecalculateParentTotalsAfterRemove"
        ]
    },
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "positionsnummer": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "bezeichnung": {
            "type": "varchar",
            "maxLength": 255,
            "options": [],
            "isCustom": true
        },
        "menge": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        },
        "einheit": {
            "type": "enum",
            "options": [
                "stk",
                "m",
                "kg",
                "std"
            ],
            "style": {
                "stk": null,
                "m": null,
                "kg": null,
                "std": null
            },
            "default": "stk",
            "maxLength": 100,
            "isCustom": true
        },
        "einzelpreisNetto": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        },
        "gesamtNetto": {
            "notNull": false,
            "type": "float",
            "isCustom": true,
            "readOnly": true
        },
        "kostenart": {
            "type": "enum",
            "options": [
                "material",
                "dienstleistung",
                "fahrzeug",
                "werkzeug",
                "buero",
                "sonstiges"
            ],
            "style": {
                "material": null,
                "dienstleistung": null,
                "fahrzeug": null,
                "werkzeug": null,
                "buero": null,
                "sonstiges": null
            },
            "default": "material",
            "maxLength": 100,
            "isCustom": true
        },
        "beschreibung": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "eingangsrechnung": {
            "type": "link"
        },
        "material": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "eingangsrechnung": {
            "type": "belongsTo",
            "foreign": "eingangsrechnungspositionen",
            "entity": "CEingangsrechnung",
            "audited": false,
            "isCustom": true
        },
        "material": {
            "type": "belongsTo",
            "foreign": "eingangsrechnungspositionen",
            "entity": "CMaterial",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}