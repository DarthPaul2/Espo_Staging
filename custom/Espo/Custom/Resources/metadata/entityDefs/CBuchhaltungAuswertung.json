{
    "fields": {
        "name": {
            "type": "varchar",
            "required": true,
            "pattern": "$noBadCharacters"
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "auswertungTyp": {
            "type": "enum",
            "options": [
                "festgeschriebene_rechnungen",
                "umsatzuebersicht",
                "umsatzsteuer_uebersicht",
                "offene_forderungen",
                "kontenbewegungen",
                "festgeschriebene_eingangsrechnungen",
                "verbindlichkeiten",
                "aufwand",
                "vorsteuer",
                "kontenbewegungen_eingang",
                "festgeschriebene_zahlungen",
                "ausgleichsuebersicht",
                "zahlungseingaenge",
                "zahlungsausgaenge",
                "teilweise_ausgeglichene_belege",
                "voll_ausgeglichene_belege",
                "zahlungsuebersicht",
                "kontenbewegungen_zahlung"
            ],
            "style": {
                "festgeschriebene_rechnungen": null,
                "umsatzuebersicht": null,
                "umsatzsteuer_uebersicht": null,
                "offene_forderungen": null,
                "kontenbewegungen": null,
                "festgeschriebene_eingangsrechnungen": null,
                "verbindlichkeiten": null,
                "aufwand": null,
                "vorsteuer": null,
                "kontenbewegungen_eingang": null,
                "festgeschriebene_zahlungen": null,
                "ausgleichsuebersicht": null,
                "zahlungseingaenge": null,
                "zahlungsausgaenge": null,
                "teilweise_ausgeglichene_belege": null,
                "voll_ausgeglichene_belege": null,
                "zahlungsuebersicht": null,
                "kontenbewegungen_zahlung": null
            },
            "default": "festgeschriebene_rechnungen",
            "maxLength": 100,
            "isCustom": true
        },
        "beschreibung": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "aktiv": {
            "notNull": true,
            "type": "bool",
            "default": true,
            "isCustom": true
        },
        "phase1Verwendet": {
            "notNull": true,
            "type": "bool",
            "default": false,
            "isCustom": true
        },
        "sortierung": {
            "type": "int",
            "isCustom": true
        },
        "standardZeitraum": {
            "type": "enum",
            "options": [
                "monat",
                "quartal",
                "jahr",
                "frei"
            ],
            "style": {
                "monat": null,
                "quartal": null,
                "jahr": null,
                "frei": null
            },
            "default": "monat",
            "maxLength": 100,
            "isCustom": true
        },
        "hinweisGeschaeftsfuehrung": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "hinweisBuchhaltung": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "zeitraumVon": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "zeitraumBis": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "renderModus": {
            "type": "enum",
            "options": [
                "standard",
                "bericht"
            ],
            "style": {
                "standard": null,
                "bericht": null
            },
            "default": "bericht",
            "maxLength": 100,
            "isCustom": true
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "buchungsjournale": {
            "type": "hasMany",
            "relationName": "cBuchhaltungAuswertungBuchungsjournal",
            "foreign": "buchhaltungAuswertungen",
            "entity": "CBuchungsjournal",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": [
            "name"
        ],
        "fullTextSearch": false,
        "countDisabled": false
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    },
    "optimisticConcurrencyControl": false
}