{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "buchungsart": {
            "type": "enum",
            "options": [
                "debit",
                "credit"
            ],
            "style": {
                "debit": null,
                "credit": null
            },
            "default": "debit",
            "maxLength": 100,
            "isCustom": true
        },
        "betrag": {
            "notNull": false,
            "type": "float",
            "isCustom": true
        },
        "kontoNummer": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "kontoBezeichnung": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "buchungstext": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "belegdatum": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "quelleTyp": {
            "type": "enum",
            "options": [
                "CRechnung",
                "CEingangsrechnung"
            ],
            "style": {
                "CRechnung": null,
                "CEingangsrechnung": null
            },
            "default": "CRechnung",
            "maxLength": 100,
            "isCustom": true
        },
        "quelleIdExtern": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "quelleNummer": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "steuerFall": {
            "type": "enum",
            "options": [
                "normal",
                "ermaessigt",
                "13b",
                "steuerfrei"
            ],
            "style": {
                "normal": null,
                "ermaessigt": null,
                "13b": null,
                "steuerfrei": null
            },
            "default": "normal",
            "maxLength": 100,
            "isCustom": true
        },
        "phase1Verwendet": {
            "notNull": true,
            "type": "bool",
            "default": true,
            "isCustom": true
        },
        "beschreibung": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "buchungsjournal": {
            "type": "link"
        },
        "buchungsregel": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "buchungsjournal": {
            "type": "belongsTo",
            "foreign": "buchungen",
            "entity": "CBuchungsjournal",
            "audited": false,
            "isCustom": true
        },
        "buchungsregel": {
            "type": "belongsTo",
            "foreign": "buchungen",
            "entity": "CBuchungsregel",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}