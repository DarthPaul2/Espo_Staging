{
    "fields": {
        "name": {
            "type": "varchar",
            "required": false,
            "pattern": "$noBadCharacters",
            "options": []
        },
        "description": {
            "type": "text"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "required": false,
            "view": "views/fields/assigned-user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        },
        "journalNummer": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "belegdatum": {
            "notNull": false,
            "type": "date",
            "isCustom": true
        },
        "buchungstext": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "quelleTyp": {
            "type": "enum",
            "options": [
                "CRechnung",
                "CEingangsrechnung",
                "CZahlung"
            ],
            "style": {
                "CRechnung": null,
                "CEingangsrechnung": null,
                "CZahlung": null
            },
            "default": "CRechnung",
            "maxLength": 100,
            "isCustom": true
        },
        "quelleIdExtern": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "quelleNummer": {
            "type": "varchar",
            "maxLength": 100,
            "options": [],
            "isCustom": true
        },
        "buchhaltungStatus": {
            "type": "enum",
            "options": [
                "entwurf",
                "festgeschrieben"
            ],
            "style": {
                "entwurf": null,
                "festgeschrieben": null
            },
            "default": "festgeschrieben",
            "maxLength": 100,
            "isCustom": true
        },
        "phase1Verwendet": {
            "notNull": true,
            "type": "bool",
            "default": true,
            "isCustom": true
        },
        "beschreibung": {
            "type": "text",
            "rowsMin": 2,
            "cutHeight": 200,
            "isCustom": true
        },
        "rechnung": {
            "type": "link"
        }
    },
    "links": {
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "entityTeam",
            "layoutRelationshipsDisabled": true
        },
        "buchungen": {
            "type": "hasMany",
            "foreign": "buchungsjournal",
            "entity": "CBuchung",
            "audited": false,
            "isCustom": true
        },
        "rechnung": {
            "type": "belongsTo",
            "foreign": "buchungsjournale",
            "entity": "CRechnung",
            "audited": false,
            "isCustom": true
        },
        "buchhaltungAuswertungen": {
            "type": "hasMany",
            "relationName": "cBuchhaltungAuswertungBuchungsjournal",
            "foreign": "buchungsjournale",
            "entity": "CBuchhaltungAuswertung",
            "audited": false,
            "isCustom": true
        },
        "eingangsrechnungs": {
            "type": "hasMany",
            "foreign": "buchungsjournal",
            "entity": "CEingangsrechnung",
            "audited": false,
            "isCustom": true
        },
        "zahlung": {
            "type": "hasMany",
            "foreign": "buchungsjournal",
            "entity": "CZahlung",
            "audited": false,
            "isCustom": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc"
    },
    "indexes": {
        "name": {
            "columns": [
                "name",
                "deleted"
            ]
        },
        "assignedUser": {
            "columns": [
                "assignedUserId",
                "deleted"
            ]
        },
        "createdAt": {
            "columns": [
                "createdAt"
            ]
        },
        "createdAtId": {
            "unique": true,
            "columns": [
                "createdAt",
                "id"
            ]
        }
    }
}